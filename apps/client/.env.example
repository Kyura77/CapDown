# CapDown Client — Environment Variables
# Copy this file to .env and fill in your values.

# URL of the CapDown API backend.
# On desktop (dev): leave empty to use default http://127.0.0.1:4540
# On Android (production): set to your server URL
VITE_CAPDOWN_API_URL=https://api.capdown.net

# API key that the client sends as x-api-key header to authenticate with the backend.
# Must match CAPDOWN_API_KEY set on the API server.
VITE_CAPDOWN_API_KEY=changeme
